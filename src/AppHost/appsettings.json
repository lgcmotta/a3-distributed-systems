{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },
  "WeatherMonitorDB": {
    "Retries": 3
  },
  "BrasilApi": {
    "BaseAddress": "https://brasilapi.com.br/api",
    "Resilience": {
      "TotalRequestTimeout": "00:01:00",
      "AttemptTimeout" : "00:01:00",
      "SamplingDuration": "00:02:00"
    }
  },
  "CachingHandler": {
    "Expiration": "1.00:00:00"
  },
  "WebhookMonitorDispatcher": {
    "Timeout" : "00:02:00"
  },
  "WeatherMonitorProcessor": {
    "CronExpression": "*/2 * * * *",
    "MaxConcurrency": 1,
    "ForecastDays": 2
  }
}